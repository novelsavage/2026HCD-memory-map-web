[
  { "id": "DEMO-001", "event_id": "reitaku-hcd-2026", "nickname": "たろう", "memory_text": "あすなろ前の桜の下で友達と毎年写真を撮った。卒業式の日の一枚は今も宝物。", "genre": "友情", "era": "1980年代", "latitude": 35.834300, "longitude": 139.956100, "captured_at": "2026-06-13T10:12:00+09:00", "card_url": null, "reitaku_dummy": true },
  { "id": "DEMO-002", "event_id": "reitaku-hcd-2026", "nickname": "はなこ", "memory_text": "図書館の窓際の席でいつも試験勉強。夕日がきれいで、つい手が止まった。", "genre": "学業", "era": "2005年代", "latitude": 35.833500, "longitude": 139.957200, "captured_at": "2026-06-13T10:20:00+09:00", "card_url": null, "reitaku_dummy": true },
  { "id": "DEMO-003", "event_id": "reitaku-hcd-2026", "nickname": "K.S.", "memory_text": "食堂のカレーが安くてうまかった。部活帰りに大盛りを頼むのが日課。", "genre": "部活", "era": "1970年代", "latitude": 35.833100, "longitude": 139.955600, "captured_at": "2026-06-13T10:31:00+09:00", "card_url": null, "reitaku_dummy": true },
  { "id": "DEMO-004", "event_id": "reitaku-hcd-2026", "nickname": "まみ", "memory_text": "学園祭の実行委員で徹夜した中庭。朝日を見ながらみんなで食べたパンの味が忘れられない。", "genre": "行事", "era": "1980年代", "latitude": 35.834000, "longitude": 139.956700, "captured_at": "2026-06-13T10:45:00+09:00", "card_url": null, "reitaku_dummy": true },
  { "id": "DEMO-005", "event_id": "reitaku-hcd-2026", "nickname": "ゆう", "memory_text": "かえで前のベンチで告白しました。今の妻です。", "genre": "恋愛", "era": "2005年代", "latitude": 35.833700, "longitude": 139.955300, "captured_at": "2026-06-13T11:02:00+09:00", "card_url": null, "reitaku_dummy": true },
  { "id": "DEMO-006", "event_id": "reitaku-hcd-2026", "nickname": "そら", "memory_text": "サッカー部の朝練で毎日走ったグラウンド。冬の霜柱を踏む音が好きだった。", "genre": "部活", "era": "2025年代", "latitude": 35.832800, "longitude": 139.956900, "captured_at": "2026-06-13T11:15:00+09:00", "card_url": null, "reitaku_dummy": true },
  { "id": "DEMO-007", "event_id": "reitaku-hcd-2026", "nickname": null, "memory_text": "ゼミの先生に叱られて、そのあと研究室でこっそりお菓子をくれた。", "genre": "学業", "era": "1980年代", "latitude": 35.834500, "longitude": 139.956500, "captured_at": "2026-06-13T11:24:00+09:00", "card_url": null, "reitaku_dummy": true },
  { "id": "DEMO-008", "event_id": "reitaku-hcd-2026", "nickname": "あき", "memory_text": "寮の屋上から見た花火。みんなで浴衣を着て、夏が終わるのが寂しかった。", "genre": "行事", "era": "1970年代", "latitude": 35.833200, "longitude": 139.957500, "captured_at": "2026-06-13T11:40:00+09:00", "card_url": null, "reitaku_dummy": true },
  { "id": "DEMO-009", "event_id": "reitaku-hcd-2026", "nickname": "のん", "memory_text": "ブリッジの上で撮った集合写真。強風でみんなの髪がすごいことになってる。", "genre": "友情", "era": "2025年代", "latitude": 35.834200, "longitude": 139.955800, "captured_at": "2026-06-13T12:05:00+09:00", "card_url": null, "reitaku_dummy": true },
  { "id": "DEMO-010", "event_id": "reitaku-hcd-2026", "nickname": "しん", "memory_text": "初めてのアルバイト先に受かった電話をここで受けた。飛び跳ねて喜んだ。", "genre": "上記以外", "era": "2005年代", "latitude": 35.833900, "longitude": 139.957000, "captured_at": "2026-06-13T12:18:00+09:00", "card_url": null, "reitaku_dummy": true },
  { "id": "DEMO-011", "event_id": "reitaku-hcd-2026", "nickname": "りん", "memory_text": "軽音サークルのライブ。緊張で手が震えたけど、最後の曲でみんなが歌ってくれた。", "genre": "部活", "era": "2005年代", "latitude": 35.833400, "longitude": 139.955900, "captured_at": "2026-06-13T12:30:00+09:00", "card_url": null, "reitaku_dummy": true },
  { "id": "DEMO-012", "event_id": "reitaku-hcd-2026", "nickname": "ひろ", "memory_text": "雪の日、授業が休講になってキャンパスで雪合戦した。先生も参戦してきた。", "genre": "行事", "era": "1960年代", "latitude": 35.834100, "longitude": 139.956300, "captured_at": "2026-06-13T13:00:00+09:00", "card_url": null, "reitaku_dummy": true },
  { "id": "DEMO-013", "event_id": "reitaku-hcd-2026", "nickname": "めい", "memory_text": "留学生の友達と食堂で言葉を教え合った。今でも年に一度会っています。", "genre": "友情", "era": "2025年代", "latitude": 35.833000, "longitude": 139.956200, "captured_at": "2026-06-13T13:22:00+09:00", "card_url": null, "reitaku_dummy": true },
  { "id": "DEMO-014", "event_id": "reitaku-hcd-2026", "nickname": "けん", "memory_text": "卒論の提出ギリギリ、印刷室のプリンタが詰まって全員で直した。あの連帯感。", "genre": "学業", "era": "2025年代", "latitude": 35.833600, "longitude": 139.956600, "captured_at": "2026-06-13T13:45:00+09:00", "card_url": null, "reitaku_dummy": true },
  { "id": "DEMO-015", "event_id": "reitaku-hcd-2026", "nickname": "つばさ", "memory_text": "入学式の日、緊張して門の前で立ち止まっていたら先輩が声をかけてくれた。", "genre": "上記以外", "era": "1980年代", "latitude": 35.832900, "longitude": 139.955500, "captured_at": "2026-06-13T14:02:00+09:00", "card_url": null, "reitaku_dummy": true },
  { "id": "DEMO-016", "event_id": "reitaku-hcd-2026", "nickname": "わたる", "memory_text": "卒業旅行で行った北海道。大学の仲間と見た流氷は一生モノの思い出。", "genre": "友情", "era": "1980年代", "latitude": 43.061900, "longitude": 141.354500, "captured_at": "2026-06-13T14:20:00+09:00", "card_url": null, "reitaku_dummy": false },
  { "id": "DEMO-017", "event_id": "reitaku-hcd-2026", "nickname": "さち", "memory_text": "ゼミ合宿の帰りに寄った鎌倉の海。夕焼けをバックにみんなでジャンプした写真。", "genre": "行事", "era": "2005年代", "latitude": 35.316700, "longitude": 139.550000, "captured_at": "2026-06-13T14:35:00+09:00", "card_url": null, "reitaku_dummy": false },
  { "id": "DEMO-018", "event_id": "reitaku-hcd-2026", "nickname": "こう", "memory_text": "就活で初めて行った東京のビル街。不安だったけど、大学の友達の応援LINEに救われた。", "genre": "上記以外", "era": "2025年代", "latitude": 35.681200, "longitude": 139.767100, "captured_at": "2026-06-13T14:50:00+09:00", "card_url": null, "reitaku_dummy": false }
